@model IEnumerable<Mobile_shop_Frontend.Models.ProductModel>?

@{
    ViewBag.Title = "title";
}

<h2 class="text-center my-4">Product Listing</h2>

<form id="filterForm" method="get" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <label for="categoryDropdown">Category</label>
            <select id="categoryDropdown" name="categoryId" asp-items="ViewBag.Categories" class="form-control">
                <option value="">All Categories</option>
            </select>
        </div>
        <div class="col-md-4">
            <label for="brandDropdown">Brand</label>
            <select id="brandDropdown" name="brandId" asp-items="ViewBag.Brands" class="form-control">
                <option value="">All Brands</option>
            </select>
        </div>
        <div class="col-md-4 d-flex align-items-end justify-content-end">
            <button type="submit" class="btn btn-primary btn-pill">Filter</button>
        </div>
    </div>
</form>

<!-- Product List -->
<div class="row">
    @foreach (var product in Model)
    {
        <!-- Updated Product Card -->
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
            <div class="card product-card h-100">
                <div class="product-image-container">
                    <img src="@product.ProductImage" class="product-image" alt="@product.ProductName" data-id="@product.ProductId">
                    <button class="btn btn-sm position-absolute top-0 text-black end-0 m-2 rounded-circle"
                            data-bs-toggle="modal"
                            data-id="@product.ProductId">
                        <i class="fas fa-ellipsis-v"></i>
                    </button>
                </div>

                <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold mb-3 product-name" data-id="@product.ProductId">@product.ProductName</h6>

                    <div class="mt-auto">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-primary fw-bold product-price" data-id="@product.ProductId">₹@product.ProductPrice</span>
                            <span class="badge bg-info">@product.StockQuantity in stock</span>
                        </div>

                        <div class="w-100 d-inline-flex align-items-center border rounded-pill overflow-hidden shadow-sm mb-2">
                            <button class="w-25 btn text-decoration-none quantity-btn px-3 py-1"
                                    data-action="decrease" data-id="@product.ProductId"
                                    style="border-right: 1px solid #dee2e6;">
                                <i class="fas fa-minus"></i>
                            </button>
                            <input type="text" class="w-50 form-control border-0 text-center bg-transparent product-quantity"
                                   value="1" min="1" data-id="@product.ProductId" style="width: 50px;">
                            <button class="w-25 btn text-decoration-none quantity-btn px-3 py-1"
                                    data-action="increase" data-id="@product.ProductId"
                                    style="border-left: 1px solid #dee2e6;">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>


                        <button class="btn btn-primary btn-pill w-100 add-to-cart" data-id="@product.ProductId">
                            <i class="fas fa-cart-plus me-2"></i>Add to Cart
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="productDetailsModal" tabindex="-1" role="dialog" aria-labelledby="productDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="productDetailsModalLabel">Product Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <img id="productImage" src="" alt="Product Image" class="img-fluid"/>
                    </div>
                    <div class="col-md-6">
                        <p>
                            <strong>Product Name:</strong> <span id="productName"></span>
                        </p>
                        <p>
                            <strong>Brand:</strong> <span id="productBrand"></span>
                        </p>
                        <p>
                            <strong>Category:</strong> <span id="productCategory"></span>
                        </p>
                        <p>
                            <strong>Price:</strong> <span id="productPrice"></span>
                        </p>
                        <p>
                            <strong>Stock Quantity:</strong> <span id="productStock"></span>
                        </p>
                        <p>
                            <strong>Status:</strong> <span id="productStatus"></span>
                        </p>
                        <p>
                            <strong>Description:</strong> <span id="productDescription"></span>
                        </p>
                        <p>
                            <strong>Created Date:</strong> <span id="productCreatedDate"></span>
                        </p>
                        <p>
                            <strong>Modified Date:</strong> <span id="productModifiedDate"></span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Mini Cart Floating Button -->
<a asp-controller="Cart" asp-action="Index" class="btn btn-primary cart-btn">
    <i class="fas fa-shopping-cart"></i> View Cart
</a>

@section Scripts
{
    <script>
        $(document).ready(function () {
            $('[data-bs-toggle="modal"]').click(function () {
                const productId = $(this).data('id');
                console.log("reached here")
                $.ajax({
                    url: `/SalesProduct/GetProductDetails?id=${productId}`,
                    success: function (response) {
                        if (response.success) {
                            $('#productImage').attr('src', response.productImage);
                            $('#productName').text(response.productName);
                            $('#productBrand').text(response.brandName);
                            $('#productCategory').text(response.categoryName);
                            $('#productPrice').text(response.productPrice);
                            $('#productStock').text(response.stockQuantity);
                            $('#productStatus').text(response.status);
                            $('#productDescription').text(response.productDescription);
                            $('#productCreatedDate').text(response.createdDate);
                            $('#productModifiedDate').text(response.modifiedDate || '-');

                            // Show modal
                            new bootstrap.Modal(document.getElementById('productDetailsModal')).show();
                        }
                    }
                });
            });
            $('.close, .btn-secondary').on('click', function () {
                $('#productDetailsModal').modal('hide');
            });
        });
    </script>
    <script>
    $(document).ready(function () {
        $(".quantity-btn").click(function () {
            let action = $(this).data("action");
            let input = $(this).siblings(".product-quantity");
            let currentVal = parseInt(input.val());
            if (action === "increase") {
                input.val(currentVal + 1);
            } else if (action === "decrease" && currentVal > 1) {
                input.val(currentVal - 1);
            }
        });

        $(".add-to-cart").click(function () {
            let productId = $(this).data("id");
            let productName = $(`.product-name[data-id='${productId}']`).text().trim();
            let productImage = $(`.product-image[data-id='${productId}']`).attr("src");
            let productPrice = parseInt($(`.product-price[data-id='${productId}']`).text().replace("₹", "").trim(), 10);
            let quantity = parseInt($(`.product-quantity[data-id='${productId}']`).val(), 10);


            $.ajax({
                url: "/Cart/AddToCart",
                type: "POST",
                data: {
                    productId: productId,
                    productName: productName,
                    productImage: productImage,
                    productPrice: productPrice,
                    quantity: quantity
                },
                success: function () {
                    Swal.fire({
                        title: 'Success!',
                        text: "Product has been added to the cart successfully.",
                        icon: 'success',
                        confirmButtonColor: '#3085d6',
                        confirmButtonText: 'Ok'
                    });
                },
                error: function () {
                    Swal.fire({
                        title: 'Error!',
                        text: "Failed to add the product to the cart. Please try again.",
                        icon: 'error',
                        confirmButtonColor: '#d33',
                        confirmButtonText: 'Ok'
                    });
                }
            });
        });

    });
</script>
}

<style>
    .product-card {
        transition: transform 0.2s, box-shadow 0.2s;
        border-radius: 15px;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .product-image-container {
        height: 200px;
        overflow: hidden;
        position: relative;
        background: #f8f9fa;
    }

    .product-image {
        height: 100%;
        width: 100%;
        object-fit: contain;
        padding: 15px;
        transition: transform 0.3s;
    }

    .product-card:hover .product-image {
        transform: scale(1.05);
    }

    .card-body {
        flex-grow: 1;
        padding: 1.25rem;
        background: #fff;
    }

    .quantity-input {
        width: 50px;
        text-align: center;
        border: 1px solid #dee2e6;
        border-radius: 5px;
        padding: 0.375rem;
    }

    .filter-section {
        background: #fff;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
        margin-bottom: 30px;
    }

    .modal-content {
        border-radius: 15px;
    }

    .modal-body img {
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .cart-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        padding: 15px 25px;
        border-radius: 30px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
        font-weight: 500;
        z-index: 1000;
    }
</style>