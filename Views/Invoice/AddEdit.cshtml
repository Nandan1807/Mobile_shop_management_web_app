@model Mobile_shop_Frontend.Models.InvoiceModel

@{
    ViewBag.Title = "Invoice Form";
}

<div class="card card-default mt-5">
    <div class="card-header">
        <h2>@ViewBag.Title</h2>
    </div>
    <div class="card-body">
        <form asp-controller="Invoice" asp-action="Save" method="post">
            <!-- Hidden Field for InvoiceId -->
            <input type="hidden" id="invoiceId" asp-for="InvoiceId">
            <input type="hidden" id="TotalAmount" asp-for="TotalAmount">

            <div class="form-group">
                <label for="customerId">Customer</label>
                <select class="form-control rounded-0" id="customerId" asp-for="CustomerId" asp-items="ViewBag.Customers">
                    <option value="">Select Customer</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="userId">User</label>
                <select class="form-control rounded-0" id="userId" asp-for="UserId" asp-items="ViewBag.Users">
                    <option value="">Select User</option>
                </select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="paymentMethod">Payment Method</label>
                <select class="form-control rounded-0" id="paymentMethod" asp-for="PaymentMethod">
                    <option value="Cash">Cash</option>
                    <option value="Credit Card">Credit Card</option>
                    <option value="Online">Online</option>
                </select>
                <span asp-validation-for="PaymentMethod" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="paymentStatus">Payment Status</label>
                <select class="form-control rounded-0" id="paymentStatus" asp-for="PaymentStatus">
                    <option value="Pending">Pending</option>
                    <option value="Paid">Paid</option>
                </select>
                <span asp-validation-for="PaymentStatus" class="text-danger"></span>
            </div>

            <div class="form-footer">
                <button type="submit" class="btn btn-primary btn-pill">Submit</button>
                <a asp-controller="Invoice" asp-action="GetInvoices" class="btn btn-light btn-pill">Cancel</a>
            </div>
        </form>
    </div>
</div>
