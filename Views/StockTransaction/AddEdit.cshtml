@model Mobile_shop_Frontend.Models.StockTransactionModel

@{
    ViewBag.Title = "Stock Transactions Form";
}

<div class="card card-default mt-5">
    <div class="card-header">
        <h2>@ViewBag.Title</h2>
    </div>
    <div class="card-body">
        <form asp-controller="StockTransaction" asp-action="Save" method="post">
            <input type="hidden" asp-for="TransactionId"/>

            <div class="form-group">
                <label for="ProductId">Product</label>
                <select asp-for="ProductId" class="form-control rounded-0" asp-items="ViewBag.Products" required>
                    <option value="">Select Product</option>
                </select>
                <span asp-validation-for="ProductId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="UserId">User</label>
                <select asp-for="UserId" class="form-control rounded-0" asp-items="ViewBag.Users" required>
                    <option value="">Select User</option>
                </select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Transaction Type</label>
                <div>
                    <div class="form-check mr-3 mb-3 d-inline-block">
                        <input class="form-check-input" type="radio" asp-for="TransactionState" id="transactionPurchase" value="Purchase" checked>
                        <label class="form-check-label" for="transactionPurchase">Purchase</label>
                    </div>
                    <div class="form-check mr-3 mb-3 d-inline-block">
                        <input class="form-check-input" type="radio" asp-for="TransactionState" id="transactionSale" value="Sale">
                        <label class="form-check-label" for="transactionSale">Sale</label>
                    </div>
                </div>
                <span asp-validation-for="TransactionState" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="Quantity">Stock Quantity</label>
                <input type="number" class="form-control rounded-0" asp-for="StockQuantity" placeholder="Enter Quantity">
                <span asp-validation-for="StockQuantity" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="Description">Transaction Description</label>
                <textarea class="form-control rounded-0" id="Description" asp-for="TransactionDescription" placeholder="Enter Description"></textarea>
                <span asp-validation-for="TransactionDescription" class="text-danger"></span>
            </div>

            <div class="form-footer">
                <button type="submit" class="btn btn-primary btn-pill">Submit</button>
                <button asp-controller="StockTransaction" asp-action="GetStockTransactions" class="btn btn-light btn-pill">Cancel</button>
            </div>
        </form>
    </div>
</div>
