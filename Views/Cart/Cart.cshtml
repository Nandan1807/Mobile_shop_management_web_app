@model System.Collections.Generic.List<Mobile_shop_Frontend.Models.CartItem>

@{
    ViewBag.Title = "Shopping Cart";
}

<div class="container py-5">
    <h4 class="text-center mb-5 display-5 fw-bold">
        <i class="fas fa-shopping-cart me-2"></i>Shopping Cart
    </h4>

    @if (Model.Count == 0)
    {
        <div class="empty-cart text-center py-5 my-5">
            <div class="empty-icon mb-4">
                <i class="fas fa-cart-arrow-down fa-4x text-muted"></i>
            </div>
            <h4 class="mb-3 fw-semibold text-secondary">Cart Feels Lonely</h4>
            <p class="text-muted mb-4">Explore our products and fill it up!</p>
            <a asp-controller="SalesProduct" asp-action="GetProducts" class="btn btn-lg btn-outline-primary rounded-pill px-4">
                <i class="fas fa-store me-2"></i>Continue Shopping
            </a>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-6">
                <label for="customerDropdown">Customer</label>
                <select id="customerDropdown" name="customerId" asp-items="ViewBag.Customers" class="form-control">
                    <option value="">All Customers</option>
                </select>
            </div>
        </div>


        <div class="card border-0 shadow-lg overflow-hidden">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 text-light"><i class="fas fa-list-alt me-2"></i>Cart Items</h5>
            </div>

            <div class="card-body p-0 text-light">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                        <tr>
                            <th style="width: 120px;">Image</th>
                            <th>Product</th>
                            <th class="text-end">Price</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-end">Total</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="cart-item">
                                <td>
                                    <div class="position-relative overflow-hidden rounded-3" style="width: 80px; height: 80px;">
                                        <img src="@item.ProductImage" class="img-fluid position-absolute top-50 start-50 translate-middle"
                                             alt="@item.ProductName" style="object-fit: cover; max-height: 100%;">
                                    </div>
                                </td>
                                <td>
                                    <h5 class="mb-1 fw-semibold">@item.ProductName</h5>
                                </td>
                                <td class="text-end">
                                    <span class="h5 text-primary">₹@item.ProductPrice</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-inline-flex align-items-center border rounded-pill overflow-hidden shadow-sm">
                                        <button class="btn btn-link text-decoration-none update-quantity px-3 py-1"
                                                data-id="@item.ProductId" data-action="decrease"
                                                style="border-right: 1px solid #dee2e6;">
                                            <i class="fas fa-minus fa-sm"></i>
                                        </button>
                                        <input type="text" value="@item.Quantity"
                                               class="form-control border-0 text-center bg-transparent"
                                               style="width: 50px;">
                                        <button class="btn btn-link text-decoration-none update-quantity px-3 py-1"
                                                data-id="@item.ProductId" data-action="increase"
                                                style="border-left: 1px solid #dee2e6;">
                                            <i class="fas fa-plus fa-sm"></i>
                                        </button>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <span class="h5 text-primary">₹@item.TotalPrice</span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-pill btn-outline-secondary remove-item"
                                            data-id="@item.ProductId" title="Remove item">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="card-footer bg-transparent py-4">
                    <div class="row align-items-center">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <a asp-controller="SalesProduct" asp-action="GetProducts"
                               class="btn btn-outline-primary rounded-pill px-4">
                                <i class="fas fa-arrow-left me-2"></i>Continue Shopping
                            </a>
                        </div>

                        <div class="col-md-6 d-flex justify-content-end">
                            <div class="d-flex align-items-center">
                                <h5 class="mt-2 me-4">
                                    <span class="text-muted me-2">Total:</span>
                                    <span class="text-success">₹@Model.Sum(item => item.TotalPrice)</span>
                                </h5>
                                <button type="button" class="btn btn-primary rounded-pill" id="checkoutButton" data-bs-target="#checkoutModal" data-bs-toggle="modal">
                                    Checkout
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Checkout Modal -->
<div class="modal fade" id="checkoutModal" tabindex="-1" aria-labelledby="checkoutModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="checkoutModalLabel">Select Payment Method</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="checkoutForm">
                    <label for="paymentMethod">Payment Method:</label>
                    <select id="paymentMethod" class="form-control">
                        <option value="Cash">Cash</option>
                        <option value="Credit Card">Credit Card</option>
                        <option value="Online">Online</option>
                    </select>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" onclick="handleCheckout()">Confirm & Pay</button>
            </div>
        </div>
    </div>
</div>

<style>
    .cart-item:hover {
        background-color: #f8f9fa;
    }

    .update-quantity {
        padding: 8px 12px;
        transition: all 0.2s ease;
    }
    
    input.form-control {
        max-width: 60px;
        text-align: center;
        font-weight: bold;
    }
    
    .remove-item {
        transition: all 0.2s ease;
    }

    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table td {
        vertical-align: middle;
        padding: 1.25rem;
    }

    .form-control:focus {
        box-shadow: none;
        border-color: #dee2e6;
    }

    .cart-item:hover {
        color: white !important; 
    }

    .cart-item:hover td,
    .cart-item:hover td h5,
    .cart-item:hover td small,
    .cart-item:hover td span,
    .cart-item:hover td button,
    .cart-item:hover td i {
        color: white !important;
    }

    .cart-item:hover .btn-outline-danger {
        border-color: white !important;
        color: white !important;
    }

    .cart-item:hover i {
        color: white !important;
    }

    .cart-item:hover input {
        background-color: transparent !important;
        color: white !important;
        border-color: white !important;
    }


</style>

@section Scripts {
    <script>
    function handleCheckout() {
        var paymentMethod = document.getElementById("paymentMethod").value;
        var customerId = document.getElementById("customerDropdown").value;

        fetch('/Cart/HandleCheckout', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({CustomerId :customerId, PaymentMethod: paymentMethod })
        })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Success!',
                        text: "Order has been placed successfully.",
                        icon: 'success',
                        confirmButtonColor: '#3085d6',
                        confirmButtonText: 'Ok'
                    }).then(()=>window.location.href = "/Cart/Index");
                } else {
                    Swal.fire({
                        title: 'Error!',
                        text: "Failed to place the order. Please try again.",
                        icon: 'error',
                        confirmButtonColor: '#d33',
                        confirmButtonText: 'Ok'
                    }).then(()=>window.location.href = "/Cart/Index");                }
            })
            .catch(error => console.error('Error:', error));
    }
</script>

    <script>
        
    $(".update-quantity").click(function (e) {
        e.preventDefault();
        const $btn = $(this);
        const productId = $btn.data("id");
        const action = $btn.data("action");
        var customerId = document.getElementById("customerDropdown").value;

        $btn.prop("disabled", true).html(`<i class="fas fa-spinner fa-spin"></i>`);

        $.post("/Cart/UpdateQuantity", { productId, action }, function () {
            window.location.href = "/Cart/Index/?customerId="+customerId
        }).fail(function () {
            $btn.prop("disabled", false).html(action === 'increase' ? '<i class="fas fa-plus"></i>' : '<i class="fas fa-minus"></i>');
            alert("Error updating quantity. Please try again.");
        });
    });

    // Remove item with confirmation
    $(".remove-item").click(function (e) {
        e.preventDefault();
        const productId = $(this).data("id");
        var customerId = document.getElementById("customerDropdown").value;

        Swal.fire({
            title: 'Remove Item?',
            text: "Are you sure you want to remove this item from your cart?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Yes, remove it!'
        }).then((result) => {
            if (result.isConfirmed) {
                $(this).html('<i class="fas fa-spinner fa-spin"></i>').prop("disabled", true);
                $.post("/Cart/RemoveFromCart", { productId }, function () {
                    window.location.href = "/Cart/Index/?customerId="+customerId
                    });
            }
        });
    });

    </script>
}