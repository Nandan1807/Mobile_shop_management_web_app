@model IEnumerable<Mobile_shop_Frontend.Models.BrandModel>

@{
ViewBag.Title = "Brands Table";
}

<div asp-validation-summary="All" class="text-danger"></div>

<div class="card card-default mt-5">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2>@ViewBag.Title</h2>
        <a asp-controller="Brand" asp-action="AddEdit" class="btn btn-primary btn-pill">Add Brand</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="productsTable" class="table table-hover table-product" style="width:100%">
                <thead>
                <tr>
                    <th>Brand Name</th>
                    <th>Created Date</th>
                    <th>Modified Date</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var brand in Model)
                {
                <tr>
                    <td>@brand.BrandName</td>
                    <td>@brand.CreatedDate.ToString("dd/MM/yyyy")</td>
                    <td>@(brand.ModifiedDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                    <td>
                        <div class="dropdown">
                            <a class="dropdown-toggle icon-burger-mini" role="button" id="dropdownMenuLink" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false"></a>
                            <div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownMenuLink">
                                <a class="dropdown-item" asp-controller="Brand" asp-action="AddEdit" asp-route-id="@brand.BrandId">Edit</a>
                                <a class="dropdown-item" asp-controller="Brand" asp-action="Delete" asp-route-id="@brand.BrandId">Delete</a>
                            </div>
                        </div>
                    </td>
                </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
